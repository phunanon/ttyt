datasource db {
  provider = "sqlite"
  url      = "file:./db.db"
}

generator client {
  provider = "prisma-client-js"
}

model Identity {
  id                   Int                @id @default(autoincrement())
  createdSec           Int
  identity             String             @unique
  addressBookEntries   AddressBookEntry[] @relation("Owner")
  inAddressBookEntries AddressBookEntry[] @relation("Contact")
  sentMail             Mail[]             @relation("Sender")
  receivedMail         Mail[]             @relation("Recipient")
}

model AddressBookEntry {
  id         Int      @id @default(autoincrement())
  createdSec Int
  ownerId    Int
  contactId  Int
  owner      Identity @relation("Owner", fields: [ownerId], references: [id])
  contact    Identity @relation("Contact", fields: [contactId], references: [id])

  @@unique([ownerId, contactId])
}

model Mail {
  id          Int      @id @default(autoincrement())
  createdSec  Int
  senderId    Int
  recipientId Int
  body        String
  bodySig     String
  firstLine   String
  sender      Identity @relation("Sender", fields: [senderId], references: [id])
  recipient   Identity @relation("Recipient", fields: [recipientId], references: [id])
}
