datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

model Identity {
  id           Int       @id @default(autoincrement())
  createdSec   Int
  identity     String    @unique
  alias        String    @unique
  contacts     Contact[] @relation("Owner")
  receivedMail Mail[]    @relation("Recipient")
}

model Contact {
  id       Int      @id @default(autoincrement())
  addedSec Int
  ownerId  Int
  identity String
  alias    String
  owner    Identity @relation("Owner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, identity])
}

model Mail {
  id          Int      @id @default(autoincrement())
  sentSec     Int
  identity    String
  recipientId Int
  body        String
  bodySig     String
  firstLine   String
  recipient   Identity @relation("Recipient", fields: [recipientId], references: [id], onDelete: Cascade)
}
