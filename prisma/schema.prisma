datasource db {
  provider = "sqlite"
  url      = "file:./db.db"
}

generator client {
  provider = "prisma-client-js"
}

model Post {
  createdSec  Int
  authorId    Int
  content     String
  signature   String
  public      Boolean
  recipientId Int
  author      PowIdentity @relation("Author", fields: [authorId], references: [id])
  recipient   PowIdentity @relation("Recipient", fields: [recipientId], references: [id])

  @@id([createdSec, authorId])
}

model PowIdentity {
  id         Int           @id @default(autoincrement())
  createdSec Int
  identity   String        @unique
  ownerId    Int?
  Authored   Post[]        @relation("Author")
  Received   Post[]        @relation("Recipient")
  owner      PowIdentity?  @relation("Owner", fields: [ownerId], references: [id])
  assets     PowIdentity[] @relation("Owner")
}
