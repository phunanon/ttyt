datasource db {
  provider = "sqlite"
  url      = "file:./db.db"
}

generator client {
  provider = "prisma-client-js"
}

model Post {
  createdSec  BigInt
  authorId    Int
  content     String
  public      Boolean
  recipientId Int
  author      PowIdentity @relation("Author", fields: [authorId], references: [id])
  recipient   PowIdentity @relation("Recipient", fields: [recipientId], references: [id])

  @@id([createdSec, authorId])
}

model PowIdentity {
  id          Int           @id @default(autoincrement())
  createdSec  BigInt
  lastQueryMs BigInt
  identity    String        @unique
  parentId    Int?
  Authored    Post[]        @relation("Author")
  Received    Post[]        @relation("Recipient")
  parent      PowIdentity?  @relation("Parent", fields: [parentId], references: [id])
  children    PowIdentity[] @relation("Parent")
}
